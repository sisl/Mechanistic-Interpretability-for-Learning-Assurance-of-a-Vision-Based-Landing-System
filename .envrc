# direnv config. Loaded automatically when you `cd` into this repo.
#
# Local defaults (CPU, DRY=1) let `make all` run end-to-end in under a
# minute so the pipeline wiring can be debugged without a GPU. Override
# on bend with `DRY= DEVICE=cuda:0 DEVICE2=cuda:1 make ...`.

export DRY=1
export DEVICE=cuda:0
export DEVICE2=cuda:1
export SEED=0
export VARIANT=pretrained
export RESULTS_DIR=results
export MODEL_DIR=models
export DATA_DIR=data
export FIG_DIR=figs

# Prefer a local Julia depot if one exists (keeps KSVD.jl install scoped
# to this project).
if [ -d "${PWD}/.julia" ]; then
  export JULIA_DEPOT_PATH="${PWD}/.julia:${JULIA_DEPOT_PATH:-}"
fi
